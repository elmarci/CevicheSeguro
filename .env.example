# ── PostgreSQL ──────────────────────────────────────────────────────────────────
POSTGRES_USER=ceviche_user
POSTGRES_PASSWORD=ceviche_pass
POSTGRES_DB=ceviche_db

# ── Backend (FastAPI) ───────────────────────────────────────────────────────────
# En local con docker-compose usa "db" como host (nombre del servicio)
# En Railway usa la URL interna que te da el servicio PostgreSQL
DATABASE_URL=postgresql://ceviche_user:ceviche_pass@db:5432/ceviche_db

SECRET_KEY=cambia_esto_por_una_clave_aleatoria_larga_min32chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Frontend (Vite / React) ─────────────────────────────────────────────────────
# En local: http://localhost:8000
# En Railway: URL pública del servicio backend, ej. https://cevicheseguro-backend.up.railway.app
VITE_API_URL=http://localhost:8000
